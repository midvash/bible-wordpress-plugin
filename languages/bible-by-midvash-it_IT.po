msgstr ""
"Collega automaticamente i nomi delle versioni della Bibbia citati nel testo"

#: includes/class-bbmv-admin.php:718
msgid "Link book names"
msgstr "Collega i nomi dei libri"

#: includes/class-bbmv-admin.php:720
