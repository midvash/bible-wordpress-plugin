#: includes/class-bbmv-admin.php:479
msgid ""
"Select the language for links and book names. This determines the URL "
"structure on Midvash."
msgstr ""
"Seleziona la lingua per link e nomi dei libri. Questo determina la struttura "
"degli URL su Midvash."

#: includes/class-bbmv-admin.php:519
msgid ""
"Select the Bible version for links and tooltips. Versions are fetched "
"dynamically from Midvash."
msgstr ""
"Seleziona la versione della Bibbia per link e tooltip. Le versioni sono "
"caricate dinamicamente da Midvash."

#: includes/class-bbmv-admin.php:533
msgid "Enable custom color for links"
msgstr "Abilita colore personalizzato per i link"

#: includes/class-bbmv-admin.php:547
msgid "Main color of the generated links."
msgstr "Colore principale dei link generati."

#: includes/class-bbmv-admin.php:560
