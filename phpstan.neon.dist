# PHPStan config — tools are installed globally (composer global), see CLAUDE.md.
# The szepeviktor/phpstan-wordpress extension is auto-loaded via phpstan/extension-installer.
parameters:
    level: 5
    # PHPDoc types are aspirational in WP land (callers can pass anything) — keep runtime guards meaningful.
    treatPhpDocTypesAsCertain: false
    paths:
        - bible-by-midvash.php
        - uninstall.php
        - includes
    scanFiles:
        - %env.HOME%/.composer/vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    excludePaths:
        - vendor
        - dist
    ignoreErrors:
        # BBMV_* constants are defined at runtime in bible-by-midvash.php (top-level define()).
        - identifier: constant.notFound
          message: '#Constant BBMV_[A-Z_]+ not found#'
        # PCRE sets non-participating groups before a matched later group to '' — the
        # emptiness check is load-bearing for ranges like "Gen 3-5"; PHPStan infers
        # numeric-string and thinks it can never be ''.
        - identifier: notIdentical.alwaysTrue
          path: includes/class-bbmv-books.php
        # Defensive guard around always-populated $css_styles; kept for readability.
        - identifier: empty.variable
          path: bible-by-midvash.php
